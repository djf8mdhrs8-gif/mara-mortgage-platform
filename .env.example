# Copy to .env and adjust as needed. .env is gitignored — never commit real secrets.

# --- Local infrastructure (docker-compose) ---
POSTGRES_USER=mara
POSTGRES_PASSWORD=mara_dev_password
POSTGRES_DB=mara_mortgage
POSTGRES_PORT=5432
REDIS_PORT=6379

# --- apps/api ---
# Prisma connection string (matches the docker-compose defaults above)
DATABASE_URL=postgresql://mara:mara_dev_password@localhost:5432/mara_mortgage
REDIS_URL=redis://localhost:6379
API_PORT=3001

# JWT secrets — generate real values with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace_me_dev_only
JWT_REFRESH_SECRET=replace_me_dev_only_2
