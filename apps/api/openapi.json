  "info": {
    "title": "Mara Mortgage API",
    "description": "",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "jane@example.com"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "maxLength": 128
          },
          "firstName": {
            "type": "string",
            "example": "Jane"
          },
          "lastName": {
            "type": "string",
            "example": "Doe"
          },
          "phone": {
            "type": "string",
            "example": "+15555550123"
          }
        },
        "required": [
          "email",
          "password",
          "firstName",
          "lastName"
        ]
      },
      "AuthUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "BORROWER",
              "REALTOR",
              "LOAN_OFFICER",
              "ADMIN"
            ]
          }
        },
        "required": [
          "id",
          "email",
          "firstName",
          "lastName",
          "role"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "Short-lived JWT (15 min) for Authorization: Bearer"
          },
          "refreshToken": {
            "type": "string",
            "description": "Long-lived opaque token; rotates on every refresh"
          },
          "user": {
            "$ref": "#/components/schemas/AuthUserDto"
          }
        },
        "required": [
          "accessToken",
          "refreshToken",
          "user"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RefreshDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "description": "Opaque refresh token issued at login/refresh"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "LogoutDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "ApplicationDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "ariveLoanId": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "SUBMITTED",
              "PROCESSING",
              "UNDERWRITING",
              "CONDITIONALLY_APPROVED",
              "CLEAR_TO_CLOSE",
              "CLOSED",
              "CANCELLED"
            ]
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "userId",
          "status",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdateApplicationStatusDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "SUBMITTED",
              "PROCESSING",
              "UNDERWRITING",
              "CONDITIONALLY_APPROVED",
              "CLEAR_TO_CLOSE",
              "CLOSED",
              "CANCELLED"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "AmortizationPdfRequestDto": {
        "type": "object",
        "properties": {
          "principal": {
            "type": "number",
            "description": "Loan amount in dollars",
            "example": 200000
          },
          "annualRatePct": {
            "type": "number",
            "description": "Annual rate percentage",
            "example": 6.5
          },
          "termMonths": {
            "type": "number",
            "description": "Term in months",
            "example": 360
          },
          "label": {
            "type": "string",
            "description": "Label shown on the PDF header",
            "example": "123 Main St"
          },
          "extraMonthly": {
            "type": "number",
            "description": "Extra principal every month (dollars)"
          },
          "extraAnnual": {
            "type": "number",
            "description": "Annual lump sum applied every 12th payment (dollars)"
          },
          "oneTimeAmount": {
            "type": "number",
            "description": "One-time extra payment amount (dollars)"
          },
          "oneTimeMonth": {
            "type": "number",
            "description": "Payment number the one-time extra applies to"
          }
        },
        "required": [
          "principal",
          "annualRatePct",
          "termMonths"
        ]
      },
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          },
          "db": {
            "type": "string",
            "enum": [
              "up"
            ]
          },
          "uptimeSeconds": {
            "type": "number",
            "description": "Process uptime in whole seconds"
          },
          "timestamp": {
            "type": "string",
            "description": "ISO-8601 server time"
          }
        },
        "required": [
          "status",
          "db",
          "uptimeSeconds",
          "timestamp"
        ]
      }
    }
  }
}
