{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/health": {
      "get": {
        "operationId": "HealthController_check_v1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Service and database are up",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponseDto"
                }
              }
            }
          },
          "503": {
            "description": "Database is unreachable"
          }
        },
        "tags": [
          "health"
        ]
      }
    }
  },
  "info": {
    "title": "Mara Mortgage API",
    "description": "",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          },
          "db": {
            "type": "string",
            "enum": [
              "up"
            ]
          },
          "uptimeSeconds": {
            "type": "number",
            "description": "Process uptime in whole seconds"
          },
          "timestamp": {
            "type": "string",
            "description": "ISO-8601 server time"
          }
        },
        "required": [
          "status",
          "db",
          "uptimeSeconds",
          "timestamp"
        ]
      }
    }
  }
}
