{
  "expo": {
    "name": "Mara Mortgage",
    "slug": "mara-mortgage",
    "version": "0.1.0",
    "scheme": "maramortgage",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/branding/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.maramortgage.app"
    },
    "android": {
      "package": "com.maramortgage.app",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/splash-check.png",
        "backgroundColor": "#4B637D"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/branding/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#4B637D",
          "image": "./assets/branding/splash-check.png",
          "imageWidth": 160
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
